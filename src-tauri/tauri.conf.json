{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Columba",
  "version": "0.1.0",
  "identifier": "com.columba.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Columba",
        "width": 1600,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon_32.png", "icons/icon_128.png", "icons/icon_512.png"],
    "externalBin": ["binaries/llama-server"],
    "resources": {
      "resources/models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf": "models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
